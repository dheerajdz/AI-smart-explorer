PORT=3000

# MongoDB
MONGO_URI=mongodb://localhost:27017/smart-ai-explorer
# For Atlas: MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/smart-explorer?retryWrites=true&w=majority

# Redis
REDIS_URL=redis://localhost:6379

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_NUMBER=your_twilio_whatsapp_number_here

# Kimi AI
KIMI_API_KEY=your_kimi_api_key_here

# XDC Blockchain APIs
BLOCKSCOUT_API=https://blockscout.xdc.network/api
XDCSCAN_API=https://api.xdcscan.io/api

# Email / SMTP (for OTP)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your_ethereal_user
SMTP_PASS=your_ethereal_password
SMTP_FROM=noreply@smartaiexplorer.com
SMTP_SECURE=false

# AI / NLU (OpenRouter)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Stripe (from GCX project)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# Slack (optional)
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# X / Twitter (optional)
X_API_KEY=...
X_API_SECRET=...
X_ACCESS_TOKEN=...
X_ACCESS_SECRET=...
